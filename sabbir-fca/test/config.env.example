# Copy this file to test/config.env and fill in real values.
# Integration tests auto-load test/config.env via dotenv.
# Shell env vars still take precedence if you need overrides.

# Login email for credential-based integration tests.
FCA_TEST_EMAIL=example@test.com

# Login password for credential-based integration tests.
FCA_TEST_PASSWORD=qwerty

# Expected current account ID after login (used for identity assertions).
FCA_TEST_USER_ID=00000000000000

# Comma-separated user thread IDs for direct-message send tests.
# The test will try these IDs in order.
FCA_TEST_USER_IDS=11111111111111,22222222222222

# Group thread ID used by group send-message tests.
FCA_TEST_GROUP_ID=3333333333333333

# E2EE direct chat target (numeric ID or full chat JID).
# If numeric, integration tests convert to <id>@msgr.
E2EE_TEST_USER_ID=1111111111111111

# E2EE group chat target (numeric ID or full chat JID).
# If numeric, integration tests convert to <id>@g.us.
E2EE_TEST_GROUP_ID=2222222222222222

# E2EE send tests require inbound activity from E2EE_TEST_USER_ID before sending.
# Send a message from this user to bot first to warm up session.
